# Normalize line endings to LF in the repo, checkout as-is on Windows
* text=auto
*.js text eol=lf
*.md text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.py text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binaries
*.png binary
*.jpg binary
*.mp3 binary
*.mp4 binary
*.zip binary
*.xlsx binary
*.exe binary
